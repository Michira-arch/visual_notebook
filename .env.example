# Gemini API Key (auto-injected in AI Studio, optional if using other providers)
GEMINI_API_KEY="your_gemini_key_here"

# All other provider keys are set in the app's Settings modal (stored in localStorage).
# You can optionally pre-configure them here and expose via vite.config.ts if needed.
# OPENAI_API_KEY="sk-..."
# DEEPSEEK_API_KEY="sk-..."
# GROQ_API_KEY="gsk_..."

APP_URL="MY_APP_URL"

# Security token shared between the Python backend and the Vite frontend.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left blank, a random token is auto-generated each time server.py starts (printed to console).
APP_SECRET_TOKEN="your_secret_token_here"
