# Gemini API Key (auto-injected in AI Studio, optional if using other providers)
GEMINI_API_KEY="your_gemini_key_here"

# All other provider keys are set in the app's Settings modal (stored in localStorage).
# You can optionally pre-configure them here and expose via vite.config.ts if needed.
# OPENAI_API_KEY="sk-..."
# DEEPSEEK_API_KEY="sk-..."
# GROQ_API_KEY="gsk_..."

APP_URL="MY_APP_URL"
